{
  "name": "imersao-machine-controller",
  "version": "1.0.0",
  "description": "Aplicativo desktop para controle de maquina de imersao baseada em impressora 3D.",
  "main": "dist-electron/main.js",
  "author": "Codex",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"npm:dev:electron\"",
    "dev:electron": "tsc -p electron/tsconfig.json && wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "setup:python": "python3 -m pip install -r electron/python/requirements.txt",
    "setup:python:win": "py -3 -m pip install -r electron/python/requirements.txt",
    "build:bridge:linux": "python3 -m pip install -r electron/python/requirements-build.txt && pyinstaller --onefile --name printcore_bridge --distpath electron/python/bin electron/python/printcore_bridge.py",
    "build": "tsc && vite build && tsc -p electron/tsconfig.json",
    "dist": "npm run build && electron-builder",
    "dist:linux": "npm run build && electron-builder --linux AppImage deb",
    "dist:linux:full": "npm run build:bridge:linux && npm run dist:linux",
    "dist:win": "npm run build && electron-builder --win nsis",
    "preview": "vite preview",
    "test:gcode": "tsx src/lib/gcode.test.ts"
  },
  "dependencies": {
    "lucide-react": "^0.475.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^34.0.2",
    "electron-builder": "^25.1.8",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "br.local.imersao-machine-controller",
    "productName": "Controle de Imersao",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "electron/python/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "electron/python",
        "to": "python"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
